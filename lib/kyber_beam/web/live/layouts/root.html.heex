<!DOCTYPE html>
<html lang="en" style="background:#0f1117;color:#e2e8f0;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>Kyber BEAM Dashboard</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'SF Mono', 'Fira Code', monospace; background: #0f1117; color: #e2e8f0; -webkit-text-size-adjust: 100%; }
      nav { background: #1a1d2e; border-bottom: 1px solid #2d3748; padding: 10px 12px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      nav .brand { color: #63b3ed; font-weight: bold; font-size: 1rem; margin-right: 4px; }
      nav a { color: #a0aec0; text-decoration: none; font-size: 0.85rem; padding: 6px 10px; border-radius: 6px; min-height: 36px; display: flex; align-items: center; }
      nav a:hover, nav a:active { color: #63b3ed; background: #2d3748; }
      main { padding: 16px; max-width: 1400px; margin: 0 auto; }
      @media (min-width: 768px) {
        nav { padding: 12px 24px; gap: 16px; }
        main { padding: 24px; }
        .two-col { grid-template-columns: 1fr 1fr !important; gap: 24px !important; }
      }
      /* Mobile-friendly JSON blocks */
      pre, .json-block { word-break: break-all; overflow-wrap: break-word; }
      /* Touch-friendly tap targets — use padding not flex override */
      [phx-click] { min-height: 44px; cursor: pointer; -webkit-tap-highlight-color: rgba(99,179,237,0.15); }

      /* ── Trace view ─────────────────────────────────────── */
      .trace-card {
        background: #1a1d2e; border: 1px solid #2d3748; border-radius: 8px;
        padding: 12px; margin-bottom: 4px;
      }
      .trace-token-summary {
        color: #fbd38d; font-size: 0.8rem; margin-bottom: 10px;
        padding: 6px 10px; background: #1e2435; border-radius: 6px;
      }
      .waterfall-container { display: flex; flex-direction: column; gap: 2px; }
      .wf-row {
        display: flex; align-items: center; gap: 8px;
        min-height: 28px;
      }
      .wf-label {
        color: #a0aec0; font-size: 0.7rem; width: 140px; flex-shrink: 0;
        text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .wf-track {
        flex: 1; position: relative; height: 22px;
        background: #151823; border-radius: 4px; overflow: hidden;
      }
      .wf-bar {
        position: absolute; top: 2px; bottom: 2px; border-radius: 3px;
        display: flex; align-items: center; justify-content: center;
        min-width: 24px; opacity: 0.85; transition: opacity 0.15s;
      }
      .wf-bar:hover { opacity: 1; }
      .wf-ms {
        color: #0f1117; font-size: 0.6rem; font-weight: bold;
        white-space: nowrap; padding: 0 4px;
      }
      .trace-node {
        padding: 10px 12px; border-radius: 6px; cursor: pointer;
        transition: background 0.15s; -webkit-user-select: none; user-select: none;
        width: 100%; text-align: left; font: inherit; color: inherit;
        -webkit-appearance: none; appearance: none; outline: none;
      }
      .trace-root { background: #1a1d2e; border: 1px solid #2d3748; }
      .trace-child { background: #151823; border: 1px solid #1e2435; }
      .trace-node:active { background: #242838; }
      .trace-header {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      }
      .trace-toggle { color: #4a5568; font-size: 0.75rem; width: 14px; flex-shrink: 0; }
      .trace-toggle-spacer { width: 14px; flex-shrink: 0; }
      .trace-kind { font-weight: bold; font-size: 0.8rem; }
      .trace-ts { color: #718096; font-size: 0.7rem; }
      .trace-summary {
        color: #e2e8f0; font-size: 0.8rem; margin-top: 4px;
        line-height: 1.5; word-break: break-word;
      }
      .trace-tokens {
        color: #b794f4; font-size: 0.75rem; margin-top: 4px;
      }
      /* Waterfall legend */
      .wf-legend {
        display: flex; gap: 16px; flex-wrap: wrap;
        padding: 8px 12px; margin-bottom: 10px;
        background: #151823; border-radius: 6px; font-size: 0.7rem;
      }
      .wf-legend-item {
        display: flex; align-items: center; gap: 6px; color: #a0aec0;
      }
      .wf-legend-swatch {
        width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0;
      }
      @media (max-width: 480px) {
        .wf-row { min-height: 44px; }
        .wf-track { height: 36px; }
        .wf-bar { top: 3px; bottom: 3px; }
        .wf-label { width: 100px; font-size: 0.65rem; }
        .wf-ms { font-size: 0.55rem; }
        .trace-node { padding: 12px 10px; }
        .trace-summary { font-size: 0.75rem; }
        .wf-legend { gap: 10px; font-size: 0.65rem; }
      }
    </style>
    <!-- Phoenix/LiveView JS — classic script tags for broad mobile compatibility -->
    <script src="/assets/phoenix/phoenix.min.js"></script>
    <script src="/assets/lv/phoenix_live_view.min.js"></script>
    <script>
      (function() {
        try {
          var csrfToken = document.querySelector("meta[name='csrf-token']");
          csrfToken = csrfToken ? csrfToken.content : "";
          var liveSocket = new LiveView.LiveSocket("/live", Phoenix.Socket, {
            params: {_csrf_token: csrfToken}
          });
          liveSocket.connect();
          window.liveSocket = liveSocket;
        } catch(e) {
          console.error("LiveView init failed:", e);
        }
      })();
    </script>
  </head>
  <body>
    <nav>
      <span class="brand">⚡ Kyber BEAM</span>
      <a href="/dashboard">Overview</a>
      <a href="/dashboard/deltas">Deltas</a>
      <a href="/dashboard/nodes">Nodes</a>
      <a href="/dashboard/traces">Traces</a>
      <a href="/sys">System</a>
    </nav>
    <main>
      {@inner_content}
    </main>
  </body>
</html>
