<!DOCTYPE html>
<html lang="en" style="background:#0f1117;color:#e2e8f0;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>Kyber BEAM Dashboard</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'SF Mono', 'Fira Code', monospace; background: #0f1117; color: #e2e8f0; -webkit-text-size-adjust: 100%; }
      nav { background: #1a1d2e; border-bottom: 1px solid #2d3748; padding: 10px 12px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      nav .brand { color: #63b3ed; font-weight: bold; font-size: 1rem; margin-right: 4px; }
      nav a { color: #a0aec0; text-decoration: none; font-size: 0.85rem; padding: 6px 10px; border-radius: 6px; min-height: 36px; display: flex; align-items: center; }
      nav a:hover, nav a:active { color: #63b3ed; background: #2d3748; }
      main { padding: 16px; max-width: 1400px; margin: 0 auto; }
      @media (min-width: 768px) {
        nav { padding: 12px 24px; gap: 16px; }
        main { padding: 24px; }
        .two-col { grid-template-columns: 1fr 1fr !important; gap: 24px !important; }
      }
      /* Mobile-friendly JSON blocks */
      pre, .json-block { word-break: break-all; overflow-wrap: break-word; }
      /* Touch-friendly tap targets */
      [phx-click] { min-height: 44px; display: flex; flex-direction: column; justify-content: center; }
    </style>
    <!-- Phoenix/LiveView JS — classic script tags for broad mobile compatibility -->
    <script src="/assets/phoenix/phoenix.min.js"></script>
    <script src="/assets/lv/phoenix_live_view.min.js"></script>
    <script>
      (function() {
        var csrfToken = document.querySelector("meta[name='csrf-token']");
        csrfToken = csrfToken ? csrfToken.content : "";
        var liveSocket = new LiveView.LiveSocket("/live", Phoenix.Socket, {
          params: {_csrf_token: csrfToken}
        });
        liveSocket.connect();
        window.liveSocket = liveSocket;
      })();
    </script>
  </head>
  <body>
    <nav>
      <span class="brand">⚡ Kyber BEAM</span>
      <a href="/dashboard">Overview</a>
      <a href="/dashboard/deltas">Deltas</a>
      <a href="/dashboard/nodes">Nodes</a>
      <a href="/dashboard/traces">Traces</a>
      <a href="/sys">System</a>
    </nav>
    <main>
      {@inner_content}
    </main>
  </body>
</html>
